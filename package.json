{
  "name": "hackathon-backend-api",
  "version": "1.0.0",
  "description": "Backend API for hackathon with Google OAuth, MongoDB, and Gemini AI integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:properties": "jest tests/properties --runInBand"
  },
  "keywords": [
    "hackathon",
    "api",
    "typescript",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@types/cors": "^2.8.19",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "mongoose": "^8.9.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/express-validator": "^2.20.33",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
